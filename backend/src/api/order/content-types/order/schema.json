{
  "kind": "collectionType",
  "collectionName": "orders",
  "info": {
    "singularName": "order",
    "pluralName": "orders",
    "displayName": "Order"
  },
  "options": { "draftAndPublish": false },
  "attributes": {
    "orderNumber": { "type": "string", "required": true, "unique": true },
    "customerName": { "type": "string", "required": true },
    "customerPhone": { "type": "string", "required": true },
    "customerAddress": { "type": "text" },
    "items": { "type": "json", "required": true },
    "totalPrice": { "type": "decimal", "required": true },
    "promoCode": { "type": "string" },
    "discount": { "type": "integer", "default": 0 },
    "status": {
      "type": "enumeration",
      "enum": ["yangi", "tasdiqlangan", "yetkazilmoqda", "yetkazildi", "bekor_qilindi"],
      "default": "yangi"
    },
    "paymentMethod": {
      "type": "enumeration",
      "enum": ["payme", "click", "naqd"],
      "default": "naqd"
    },
    "notes": { "type": "text" }
  }
}
