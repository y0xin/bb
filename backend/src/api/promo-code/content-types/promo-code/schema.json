{
  "kind": "collectionType",
  "collectionName": "promo_codes",
  "info": {
    "singularName": "promo_code",
    "pluralName": "promo_codes",
    "displayName": "Promo Code",
    "description": "Store discount promo codes"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "code": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "discountPercent": {
      "type": "integer",
      "required": true,
      "min": 1,
      "max": 100
    },
    "isActive": {
      "type": "boolean",
      "default": true
    },
    "expirationDate": {
      "type": "date"
    }
  }
}
